@model EnterEmailViewModel

<form asp-controller="" asp-action="" method="post" class="set-password-form">
    <div class="sign-up-input-container">
        <label asp-for="Email" class="sign-up-label">Email Address</label>
        <input asp-for="Email" disabled class="sign-up-input" placeholder="Enter Email Address">
        <input type="hidden" asp-for="Email">
        <span asp-validation-for="Email" class="email-validation"></span>

        <label class="sign-up-label">Password</label>
        <input type="text" class="sign-up-input" placeholder="Enter Password">
    </div>    

    <button type="submit" class="sign-up-button set-password-button">
        Continue
        <svg xmlns="http://www.w3.org/2000/svg" class="sign-up-chevron" width="18" height="18" fill="currentColor" class="bi bi-chevron-right" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"/>
        </svg>
    </button>

    @* Checkbox HTML and CSS is AI generated *@
    <label class="custom-checkbox">
        <input type="checkbox"/>
        <span class="set-password-checkmark"></span>
        <p class="terms-text">Accept user terms and conditions</p>
    </label>
</form>