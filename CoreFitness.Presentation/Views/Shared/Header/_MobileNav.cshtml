@{
    string? current = ViewContext.RouteData.Values["controller"]?.ToString();
}

<div class="off-screen-menu">

    <ul class="mobile-nav-list">
        <li class="mobile-link-container">
            <a href="" class="mobile-nav-link">Fitness Centers</a>
        </li>

        <li class="mobile-link-container">
            <a asp-controller="Memberships" asp-action="Index" class="mobile-nav-link @(current == "Memberships" ? "active" : "")">Memberships</a>
        </li>

        <li class="mobile-link-container">
            <a href="" class="mobile-nav-link training-nav-link">
                Training
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-chevron-down" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708"/>
                </svg>
            </a>
        </li>

        <li class="mobile-link-container">
            <a asp-controller="CustomerService" asp-action="Index" class="mobile-nav-link @(current == "CustomerService" ? "active" : "")">Customer Service</a>
        </li>

        <li class="mobile-link-container">
            <a href="" class="mobile-nav-link">Store</a>
        </li>
    </ul>

    <ul class="mobile-account-links">

        @* if statement is AI generated *@
        @if (User?.Identity?.IsAuthenticated != true)
        {
            <li>
                <a asp-controller="BecomeMember" asp-action="Index" class="mobile-nav-link">Become Member</a>        
            </li>
            <li>
                <a asp-controller="SignIn" asp-action="Index" class="mobile-sign-in-button ">
                    Sign In
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" class="bi bi-chevron-right" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"/>
                    </svg>
                </a>
            </li>
        }
        else
        {
            <li>
                <a asp-controller="MyAccount" asp-action="Index" class="mobile-sign-in-button ">
                    My Account
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" class="bi bi-chevron-right" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"/>
                    </svg>
                </a>
            </li>
        }
    </ul>

</div>

<div class="ham-container">
    <div class="ham-menu">
        <span></span>
        <span></span>
        <span></span>
    </div>
</div>