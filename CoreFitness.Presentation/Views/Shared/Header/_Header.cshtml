@{
    string? current = ViewContext.RouteData.Values["controller"]?.ToString();
}

<div class="header-container">
    <nav class="nav-container">

        <a href="/">
            <img src="~/images/logotype.svg" alt="">
        </a>

        <div class="link-container desktop-nav">
            <ul class="nav-list">
                <li>
                    <a href="" class="nav-link">Fitness Centers</a>
                </li>

                <li>
                    <a asp-controller="Memberships" asp-action="Index" class="nav-link @(current == "Memberships" ? "active" : "")">Memberships</a>
                </li>

                <li>
                    <a href="" class="nav-link training-nav-link">
                        Training
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-chevron-down" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708"/>
                        </svg>
                    </a>
                </li>

                <li>
                    <a asp-controller="CustomerService" asp-action="Index" class="nav-link @(current == "CustomerService" ? "active" : "")">Customer Service</a>
                </li>

                <li>
                    <a href="" class="nav-link">Store</a>
                </li>
            </ul>
        </div>

        <div class="account-link-container desktop-nav">
            <ul class="nav-list">
                <li>
                    <a href="" class="nav-link">Become Member</a>
                </li>

                <li>
                    <a href="" class="sign-in-button">
                        Sign In
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-right" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"/>
                        </svg>
                    </a>
                </li>
            </ul>
        </div>

        <div class="mobile-nav">
            <partial name="Header/_MobileNav"/>
        </div>

    </nav>
</div>